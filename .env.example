# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- GitHub ---
# Personal access token, "public_repo" scope is enough for public PRs.
GITHUB_TOKEN=

# --- MongoDB Atlas ---
# Full connection string, e.g. mongodb+srv://user:pass@cluster.mongodb.net/reviewbot
MONGODB_URI=
MONGODB_DB_NAME=reviewbot

# --- Backend ---
# Comma-separated list of origins allowed to call the API (Vercel domain in prod)
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
# Base URL of the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000
